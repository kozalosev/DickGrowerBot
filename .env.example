TELOXIDE_TOKEN=0123456789:XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
RUST_LOG=info

# Docker is for infrastructure only, the bot is used as a binary
POSTGRES_HOST=localhost
# Everything's running inside Docker
#POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=dickgrowerbotdb
POSTGRES_USER=dickgrowerbot
POSTGRES_PASSWORD=dgb4pwd

# DATABASE_URL is required to run a plain binary executable file for dev environment
# this line is ignored and built from the components above in `docker-compose.yml`
DATABASE_URL=postgres://dickgrowerbot:dgb4pwd@localhost:5432/dickgrowerbotdb
DATABASE_MAX_CONNECTIONS=10

HELP_ADMIN_CHANNEL_RU=kozaloru
HELP_ADMIN_CHANNEL_EN=kozalo_blog
HELP_ADMIN_CHAT_RU=kozaloru_chat
HELP_ADMIN_CHAT_EN=kozalo_blog_chat
HELP_GIT_REPO=https://github.com/kozalosev/DickGrowerBot

CHATS_MERGING_ENABLED=true
TOP_UNLIMITED_ENABLED=true
MULTIPLE_LOANS_ENABLED=false
PVP_CHECK_ACCEPTOR_LENGTH=false
PVP_CALLBACK_LOCKS_ENABLED=true

#PVP_STATS_SHOW=false
#PVP_STATS_SHOW_NOTICE=true
#DISABLE_CMD_STATS=true

GROWTH_MIN=-5
GROWTH_MAX=10
GROW_SHRINK_RATIO=0.5
GROWTH_DOD_BONUS_MAX=5
NEWCOMERS_GRACE_DAYS=7
TOP_LIMIT=10
INACTIVITY_DAYS=7
PVP_DEFAULT_BET=1

# Perks
HELP_PUSSIES_COEF=0.01
LOAN_PAYOUT_COEF=0.1

# How to select winners of DoD? Possible options:
# 1) RANDOM - completely random
# 2) EXCLUSION - exclude TOP-N% (10% if ratio is 0.1)
# 3) WEIGHTS - the less your dick is the more chances you have
DOD_SELECTION_MODE=EXCLUSION
DOD_RICH_EXCLUSION_RATIO=0.1

# Self-destruction of bot messages (issue #49, PoC). Delay in minutes before the bot
# deletes its own message; 0 (or unset) means messages of that group are permanent.
# Messages in private chats are never deleted. Only these two groups are supported so far:
#   NOTICE — help, privacy, error/status replies
#   REPORT — leaderboard (/top), /stats
#MSG_SELFDESTRUCT_DELAY_NOTICE=2
#MSG_SELFDESTRUCT_DELAY_REPORT=5
# Long messages are kept up at least long enough to be read: the delay is raised to
# max(group delay, reading time), where reading time = characters / this speed. Since it's
# a reading SPEED, a HIGHER value assumes a faster reader and deletes messages SOONER,
# while a LOWER value leaves them up longer. 0 disables the reading-time adjustment (only
# the flat per-group delay applies).
#MSG_SELFDESTRUCT_READING_SPEED_CPM=500
# Before deleting, the message is replaced with a localized "will be deleted in N seconds"
# warning shown for this many seconds (0 deletes immediately, without any warning).
#MSG_SELFDESTRUCT_WARNING_SECONDS=15

# Announcements are displayed at the end of the Dick of the Day message, not more than a specified
# amount of times. They (max_shows + per-language texts) are configured in a YAML file — edit
# announcements.yml. Override the path here if needed.
#ANNOUNCEMENTS_FILE=announcements.yml

# to enable Webhook Mode, set to a correct URL, proxied by a reverse proxy server
#WEBHOOK_URL=https://your.domain/DickGrowerBot/webhook

# Timeouts (in seconds) for the bot's HTTP client talking to the Telegram Bot API, so a stalled
# request (e.g. when the ТСПУ/DPI equipment lets the connection hang and crawl instead of resetting
# it) fails after a bounded time instead of blocking update processing. Each is optional and
# overrides only its own knob; leaving BOTH unset keeps teloxide's stock client (defaults: 5s
# connect, 17s total).
#BOT_HTTP_CONNECT_TIMEOUT_SECS=5
#BOT_HTTP_TIMEOUT_SECS=17

### Integration with the user-service microservice (https://github.com/Kozalo-Blog/user-service).

# gRPC port the bundled user-service listens on (fixed by the service). Also used to expose
# and publish the container in docker-compose. Must be defined above GRPC_ADDR_USER_SERVICE
# so the ${...} reference expands.
USER_SERVICE_GRPC_PORT=8090

# When GRPC_ADDR_USER_SERVICE is unset, the integration is disabled: per-user languages come from
# Telegram as before and the personal /language command is hidden from private chats. The chat-wide
# /language (groups, admins-only) keeps working regardless — it's stored in our own database.
# Set it to the service's gRPC address to enable reading/updating a user's preferred
# language across all of SadBot.Dev's bots. Which host to use depends on where the BOT runs:
#   * Bot as a local binary, infra in Docker (the usual dev flow): docker-compose.override.yml
#     forwards the container's port to your machine, so use localhost:${USER_SERVICE_GRPC_PORT}.
#GRPC_ADDR_USER_SERVICE=localhost:${USER_SERVICE_GRPC_PORT}
#   * Bot itself running inside docker-compose: use the service name on the Docker network,
#GRPC_ADDR_USER_SERVICE=user-service:${USER_SERVICE_GRPC_PORT}

# How long (in seconds) to cache users fetched from the service. Optional, defaults to 360.
#USER_CACHE_TIME_SECS=360
# Per-request/connection timeout (in seconds) for gRPC calls to the service, so a hanging service
# can't stall update processing. Optional, defaults to 5.
#USER_SERVICE_TIMEOUT_SECS=5
# How long (in seconds) to cache each chat's chosen language (stored in our own DB). Optional,
# defaults to 3600 — a rather aggressive TTL is fine since we own the data.
#CHAT_LANGUAGE_CACHE_TIME_SECS=3600

# --- Local user-service run (docker-compose) ---
# The bundled `user-service` container shares the same PostgreSQL server as the bot, but
# uses its own database and role (provisioned by postgres/init-user-service-db.sh on a
# fresh data volume). These configure that database. To point the bot at the bundled
# service, uncomment GRPC_ADDR_USER_SERVICE above (localhost:… for a local binary,
# user-service:… when the bot itself runs in docker-compose).
USER_SERVICE_POSTGRES_DB=userservicedb
USER_SERVICE_POSTGRES_USER=userservice
USER_SERVICE_POSTGRES_PASSWORD=us4pwd
